PORT=5000
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=internship_db
JWT_SECRET=super_secret_jwt_key_here

# Frontend URL used for "Log In" links inside notification emails
FRONTEND_URL=http://localhost:5173

# SMTP — email notifications (Phase 9)
# Gmail: use an App Password (not your regular password) with 2FA enabled.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Uncomment to bypass the OTP send-otp rate limiter during local testing.
# OTP_RATE_LIMIT_DISABLED=true
