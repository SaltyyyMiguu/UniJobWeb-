PORT=5000
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=internship_db
JWT_SECRET=super_secret_jwt_key_here

# Frontend URL used for "Log In" links inside notification emails
FRONTEND_URL=http://localhost:5173

# SMTP — email notifications (Phase 9)
# Gmail: use an App Password (not your regular password) with 2FA enabled.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Optional — set this when SMTP_USER isn't itself a deliverable "From"
# address (e.g. Brevo/SendinBlue logins are often a non-routable ID). Must
# be a sender address verified in your provider's dashboard. Falls back to
# SMTP_USER when unset, so this is safe to leave blank for Gmail.
# SENDER_EMAIL=

# Uncomment to bypass the OTP send-otp rate limiter during local testing.
# OTP_RATE_LIMIT_DISABLED=true

# Cloudinary — file storage (avatars, listing covers, cover photos, resumes,
# offer letters). Required in production: Render's disk is ephemeral, so
# anything saved locally to backend/uploads/ is lost on every restart/redeploy.
# Free tier at cloudinary.com is enough for this project — grab these three
# values from your Cloudinary dashboard's "Account Details" panel.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
